<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="windowTitle"><string>Connect-IP Tunnel</string></property>
  <property name="minimumSize"><size><width>800</width><height>560</height></size></property>

  <widget class="QWidget" name="centralWidget">
   <layout class="QVBoxLayout" name="verticalLayout">

    <!-- ── 工具栏 ── -->
    <item>
     <layout class="QHBoxLayout">
      <item><widget class="QPushButton" name="btnAdd">
       <property name="text"><string>+ 添加</string></property>
      </widget></item>
      <item><widget class="QPushButton" name="btnEdit">
       <property name="text"><string>✎ 编辑</string></property>
       <property name="enabled"><bool>false</bool></property>
      </widget></item>
      <item><widget class="QPushButton" name="btnDelete">
       <property name="text"><string>✕ 删除</string></property>
       <property name="enabled"><bool>false</bool></property>
      </widget></item>
      <item><widget class="QSpacerItem" name="spacer1"><property name="orientation"><enum>Qt::Horizontal</enum></property></widget></item>
      <item><widget class="QPushButton" name="btnConnect">
       <property name="text"><string>▶ 连接</string></property>
       <property name="enabled"><bool>false</bool></property>
      </widget></item>
      <item><widget class="QPushButton" name="btnDisconnect">
       <property name="text"><string>■ 断开</string></property>
       <property name="enabled"><bool>false</bool></property>
      </widget></item>
     </layout>
    </item>

    <!-- ── 主体：节点列表 + 状态面板 ── -->
    <item>
     <widget class="QSplitter" name="splitterMain">
      <property name="orientation"><enum>Qt::Horizontal</enum></property>

      <!-- 节点列表 -->
      <widget class="QTableWidget" name="tableNodes">
       <property name="minimumWidth"><number>280</number></property>
      </widget>

      <!-- 状态面板 -->
      <widget class="QWidget" name="statusPanel">
       <layout class="QVBoxLayout">

        <!-- 连接状态标签 -->
        <item>
         <widget class="QLabel" name="labelStatus">
          <property name="text"><string>○ 未连接</string></property>
          <property name="alignment"><set>Qt::AlignCenter</set></property>
          <property name="styleSheet"><string>color: gray; font-size: 14px;</string></property>
         </widget>
        </item>

        <!-- 统计表格 -->
        <item>
         <widget class="QGroupBox" name="groupStats">
          <property name="title"><string>连接信息</string></property>
          <layout class="QFormLayout">
           <item>
            <widget class="QLabel"><property name="text"><string>分配 IP</string></property></widget>
            <widget class="QLabel" name="labelAssignedIP"><property name="text"><string>-</string></property></widget>
           </item>
           <item>
            <widget class="QLabel"><property name="text"><string>TUN 设备</string></property></widget>
            <widget class="QLabel" name="labelTunName"><property name="text"><string>-</string></property></widget>
           </item>
           <item>
            <widget class="QLabel"><property name="text"><string>运行时间</string></property></widget>
            <widget class="QLabel" name="labelUptime"><property name="text"><string>-</string></property></widget>
           </item>
           <item>
            <widget class="QLabel"><property name="text"><string>↑ 上行</string></property></widget>
            <widget class="QLabel" name="labelTxBytes"><property name="text"><string>-</string></property></widget>
           </item>
           <item>
            <widget class="QLabel"><property name="text"><string>↓ 下行</string></property></widget>
            <widget class="QLabel" name="labelRxBytes"><property name="text"><string>-</string></property></widget>
           </item>
           <item>
            <widget class="QLabel"><property name="text"><string>↑ 上行包数</string></property></widget>
            <widget class="QLabel" name="labelTxPackets"><property name="text"><string>-</string></property></widget>
           </item>
           <item>
            <widget class="QLabel"><property name="text"><string>↓ 下行包数</string></property></widget>
            <widget class="QLabel" name="labelRxPackets"><property name="text"><string>-</string></property></widget>
           </item>
           <item>
            <widget class="QLabel"><property name="text"><string>丢包数</string></property></widget>
            <widget class="QLabel" name="labelDrops"><property name="text"><string>-</string></property></widget>
           </item>
          </layout>
         </widget>
        </item>

        <item><widget class="QSpacerItem" name="spacerV"><property name="orientation"><enum>Qt::Vertical</enum></property></widget></item>

       </layout>
      </widget>
     </widget>
    </item>

    <!-- ── 日志区 ── -->
    <item>
     <widget class="QGroupBox" name="groupLog">
      <property name="title"><string>日志</string></property>
      <property name="maximumHeight"><number>160</number></property>
      <layout class="QVBoxLayout">
       <item>
        <widget class="QTextBrowser" name="textLog">
         <property name="font">
          <font><family>Courier New</family><pointsize>9</pointsize></font>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>

   </layout>
  </widget>

  <!-- 状态栏 -->
  <widget class="QStatusBar" name="statusBar"/>
 </widget>
</ui>
