<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>EditNodeDialog</class>
 <widget class="QDialog" name="EditNodeDialog">
  <property name="windowTitle"><string>编辑节点</string></property>
  <property name="minimumSize"><size><width>620</width><height>620</height></size></property>
  <layout class="QVBoxLayout">
   <item>
    <widget class="QTabWidget" name="tabWidget">

     <!-- ── 基本设置 ── -->
     <widget class="QWidget" name="tabBasic">
      <attribute name="title"><string>基本</string></attribute>
      <layout class="QVBoxLayout">
       <item>
        <layout class="QFormLayout">
         <item row="0" column="0">
          <widget class="QLabel"><property name="text"><string>名称</string></property></widget>
         </item>
         <item row="0" column="1">
          <widget class="QLineEdit" name="editName"/>
         </item>
         <item row="1" column="0">
          <widget class="QLabel"><property name="text"><string>服务端地址 (host:port)</string></property></widget>
         </item>
         <item row="1" column="1">
          <widget class="QLineEdit" name="editServerAddr">
           <property name="placeholderText"><string>proxy.example.com:443</string></property>
          </widget>
         </item>
         <item row="2" column="0">
          <widget class="QLabel"><property name="text"><string>URI</string></property></widget>
         </item>
         <item row="2" column="1">
          <widget class="QLineEdit" name="editURI">
           <property name="placeholderText"><string>https://proxy.example.com/.well-known/masque/ip</string></property>
           <property name="toolTip"><string>支持两种写法：
• 完整 URL：https://proxy.example.com/.well-known/masque/ip（推荐，与服务端 uri_template 完全一致）
• 相对路径：/.well-known/masque/ip（自动补全为 https://&lt;authority&gt;/...）
转发场景：请使用完整 URL，域名填真正代理的域名。</string></property>
          </widget>
         </item>
         <item row="3" column="0">
          <widget class="QLabel"><property name="text"><string>Authority（连接主机名）</string></property></widget>
         </item>
         <item row="3" column="1">
          <widget class="QLineEdit" name="editAuthority">
           <property name="placeholderText"><string>留空则自动从 URI 提取</string></property>
           <property name="toolTip"><string>HTTP :authority header，必须与服务端 uri_template 的域名完全一致。
• 直连：留空即可（自动从 URI 提取域名）
• 转发：服务端地址填中继地址，此处填真正代理的域名</string></property>
          </widget>
         </item>
        </layout>
       </item>

       <!-- mTLS 证书组 -->
       <item>
        <widget class="QGroupBox" name="groupMTLS">
         <property name="title"><string>mTLS 客户端证书（唯一鉴权方式）</string></property>
         <layout class="QFormLayout">
          <item row="0" column="0">
           <widget class="QLabel"><property name="text"><string>客户端证书 (PEM)</string></property></widget>
          </item>
          <item row="0" column="1">
           <layout class="QHBoxLayout">
            <item><widget class="QLineEdit" name="editClientCertFile"><property name="placeholderText"><string>client.crt</string></property></widget></item>
            <item><widget class="QPushButton" name="btnBrowseCert"><property name="text"><string>浏览...</string></property><property name="maximumWidth"><number>64</number></property></widget></item>
           </layout>
          </item>
          <item row="1" column="0">
           <widget class="QLabel"><property name="text"><string>客户端私钥 (PEM)</string></property></widget>
          </item>
          <item row="1" column="1">
           <layout class="QHBoxLayout">
            <item><widget class="QLineEdit" name="editClientKeyFile"><property name="placeholderText"><string>client.key</string></property></widget></item>
            <item><widget class="QPushButton" name="btnBrowseKey"><property name="text"><string>浏览...</string></property><property name="maximumWidth"><number>64</number></property></widget></item>
           </layout>
          </item>
         </layout>
        </widget>
       </item>

       <item>
        <spacer name="verticalSpacer">
         <property name="orientation"><enum>Qt::Vertical</enum></property>
         <property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property>
        </spacer>
       </item>
      </layout>
     </widget>

     <!-- ── TLS/ECH ── -->
     <widget class="QWidget" name="tabTLS">
      <attribute name="title"><string>TLS / ECH</string></attribute>
      <layout class="QFormLayout">
       <item row="0" column="0">
        <widget class="QLabel"><property name="text"><string>SNI（留空同 host）</string></property></widget>
       </item>
       <item row="0" column="1">
        <widget class="QLineEdit" name="editServerName"/>
       </item>
       <!-- 注：原"跳过证书验证"复选框已永久移除：内核已禁用该字段，
            写出 false 触发 deprecated 警告，写出 true 直接拒绝启动。 -->
       <item row="1" column="0">
        <widget class="QLabel"><property name="text"><string>启用后量子密钥交换 (PQC)</string></property></widget>
       </item>
       <item row="1" column="1">
        <widget class="QCheckBox" name="checkEnablePQC"/>
       </item>
       <item row="2" column="0">
        <widget class="QLabel"><property name="text"><string>服务端 CA 证书 (PEM)</string></property></widget>
       </item>
       <item row="2" column="1">
        <layout class="QHBoxLayout">
         <item>
          <widget class="QLineEdit" name="editServerCAFile">
           <property name="placeholderText"><string>留空 = 用 Mozilla / 系统 CA；自签 CA 部署填这里</string></property>
           <property name="toolTip"><string>信任锚优先级：server_ca_file &gt; use_mozilla_ca &gt; use_system_cas
企业内网 mTLS 部署的推荐做法：用 certsrv 签发 server.crt 与 ca.crt，
把 ca.crt 路径填在这里，TLS 握手只信任本组织 CA，杜绝 MITM。</string></property>
          </widget>
         </item>
         <item><widget class="QPushButton" name="btnBrowseServerCA"><property name="text"><string>浏览...</string></property><property name="maximumWidth"><number>64</number></property></widget></item>
        </layout>
       </item>
       <item row="3" column="0">
        <widget class="QLabel"><property name="text"><string>使用 Mozilla CA 根证书</string></property></widget>
       </item>
       <item row="3" column="1">
        <widget class="QCheckBox" name="checkUseMozillaCA"><property name="checked"><bool>true</bool></property></widget>
       </item>
       <item row="4" column="0">
        <widget class="QLabel"><property name="text"><string>使用系统 CA 根证书</string></property></widget>
       </item>
       <item row="4" column="1">
        <widget class="QCheckBox" name="checkUseSystemCAs"/>
       </item>
       <item row="5" column="0">
        <widget class="QLabel"><property name="text"><string>启用 ECH</string></property></widget>
       </item>
       <item row="5" column="1">
        <widget class="QCheckBox" name="checkEnableECH"><property name="checked"><bool>true</bool></property></widget>
       </item>
       <item row="6" column="0">
        <widget class="QLabel"><property name="text"><string>ECH 查询域名</string></property></widget>
       </item>
       <item row="6" column="1">
        <widget class="QLineEdit" name="editECHDomain"><property name="placeholderText"><string>留空则同 SNI</string></property></widget>
       </item>
       <item row="7" column="0">
        <widget class="QLabel"><property name="text"><string>ECH DoH 服务器</string></property></widget>
       </item>
       <item row="7" column="1">
        <widget class="QLineEdit" name="editECHDohServer"><property name="placeholderText"><string>https://cloudflare-dns.com/dns-query</string></property></widget>
       </item>
       <item row="8" column="0">
        <widget class="QLabel"><property name="text"><string>ECH 静态配置 (Base64)</string></property></widget>
       </item>
       <item row="8" column="1">
        <widget class="QLineEdit" name="editECHConfigListB64">
         <property name="placeholderText"><string>留空则通过 DoH 动态查询（推荐）</string></property>
         <property name="toolTip"><string>填入后将跳过 DoH 查询，直接使用此静态 ECH 配置（Base64 编码）</string></property>
        </widget>
       </item>
       <item row="9" column="0">
        <widget class="QLabel"><property name="text"><string>地址族偏好</string></property></widget>
       </item>
       <item row="9" column="1">
        <widget class="QComboBox" name="comboPreferAddressFamily">
         <property name="toolTip"><string>auto: Happy Eyeballs（IPv6 优先，失败时回退 IPv4，推荐）
v4: 仅使用 IPv4
v6: 仅使用 IPv6</string></property>
         <item><property name="text"><string>auto（双栈 Happy Eyeballs）</string></property></item>
         <item><property name="text"><string>仅 IPv4</string></property></item>
         <item><property name="text"><string>仅 IPv6</string></property></item>
        </widget>
       </item>
       <item row="10" column="0">
        <widget class="QLabel"><property name="text"><string>Happy Eyeballs 延迟（毫秒）</string></property></widget>
       </item>
       <item row="10" column="1">
        <widget class="QSpinBox" name="spinHappyEyeballsDelay">
         <property name="minimum"><number>0</number></property>
         <property name="maximum"><number>5000</number></property>
         <property name="value"><number>50</number></property>
         <property name="singleStep"><number>10</number></property>
         <property name="suffix"><string> ms</string></property>
         <property name="specialValueText"><string>内核默认</string></property>
         <property name="toolTip"><string>双栈环境中 IPv6 与 IPv4 之间的交错延迟。
RFC 8305 推荐 250ms；本项目默认 50ms（更激进）。</string></property>
        </widget>
       </item>
      </layout>
     </widget>

     <!-- ── TUN ── -->
     <widget class="QWidget" name="tabTUN">
      <attribute name="title"><string>TUN</string></attribute>
      <layout class="QFormLayout">
       <item row="0" column="0">
        <widget class="QLabel"><property name="text"><string>TUN 设备名</string></property></widget>
       </item>
       <item row="0" column="1">
        <widget class="QLineEdit" name="editTunName"><property name="placeholderText"><string>tun0</string></property></widget>
       </item>
       <item row="1" column="0">
        <widget class="QLabel"><property name="text"><string>MTU</string></property></widget>
       </item>
       <item row="1" column="1">
        <widget class="QSpinBox" name="spinMTU">
         <property name="minimum"><number>1280</number></property>
         <property name="maximum"><number>65535</number></property>
         <property name="value"><number>1400</number></property>
        </widget>
       </item>
       <item row="2" column="0">
        <widget class="QLabel"><property name="text"><string>DNS IPv4</string></property></widget>
       </item>
       <item row="2" column="1">
        <widget class="QLineEdit" name="editDnsV4"><property name="placeholderText"><string>1.1.1.1</string></property></widget>
       </item>
       <item row="3" column="0">
        <widget class="QLabel"><property name="text"><string>DNS IPv6</string></property></widget>
       </item>
       <item row="3" column="1">
        <widget class="QLineEdit" name="editDnsV6"><property name="placeholderText"><string>2606:4700:4700::1111</string></property></widget>
       </item>

       <!-- 地址分配模式 -->
       <item row="4" column="0">
        <widget class="QLabel"><property name="text"><string>等待服务端分配 IP</string></property></widget>
       </item>
       <item row="4" column="1">
        <widget class="QCheckBox" name="checkWaitForAddressAssign">
         <property name="checked"><bool>true</bool></property>
         <property name="toolTip"><string>勾选：等待服务端通过 ADDRESS_ASSIGN 分配 IP（默认）
取消：手动填写静态 IP（仅当服务端未开启地址分配时使用）</string></property>
        </widget>
       </item>
       <item row="5" column="0">
        <widget class="QLabel"><property name="text"><string></string></property></widget>
       </item>
       <item row="5" column="1">
        <widget class="QLabel" name="labelStaticIPHint">
         <property name="text"><string>⚠ 静态 IP 模式：仅当服务端未开启地址分配功能时使用</string></property>
         <property name="styleSheet"><string>color: #cc6600; font-style: italic;</string></property>
         <property name="wordWrap"><bool>true</bool></property>
        </widget>
       </item>
       <item row="6" column="0">
        <widget class="QLabel" name="labelIPv4CIDR"><property name="text"><string>IPv4 CIDR</string></property></widget>
       </item>
       <item row="6" column="1">
        <widget class="QLineEdit" name="editIPv4CIDR">
         <property name="placeholderText"><string>10.0.0.2/24</string></property>
         <property name="enabled"><bool>false</bool></property>
        </widget>
       </item>
       <item row="7" column="0">
        <widget class="QLabel" name="labelIPv6CIDR"><property name="text"><string>IPv6 CIDR</string></property></widget>
       </item>
       <item row="7" column="1">
        <widget class="QLineEdit" name="editIPv6CIDR">
         <property name="placeholderText"><string>fd00::2/64</string></property>
         <property name="enabled"><bool>false</bool></property>
        </widget>
       </item>
      </layout>
     </widget>

     <!-- ── 高级 ── -->
     <widget class="QWidget" name="tabAdvanced">
      <attribute name="title"><string>高级</string></attribute>
      <layout class="QFormLayout">
       <item row="0" column="0">
        <widget class="QLabel"><property name="text"><string>允许 0-RTT</string></property></widget>
       </item>
       <item row="0" column="1">
        <widget class="QCheckBox" name="checkAllow0RTT"/>
       </item>
       <item row="1" column="0">
        <widget class="QLabel"><property name="text"><string>断线自动重连</string></property></widget>
       </item>
       <item row="1" column="1">
        <widget class="QCheckBox" name="checkEnableReconnect"><property name="checked"><bool>true</bool></property></widget>
       </item>
       <item row="2" column="0">
        <widget class="QLabel"><property name="text"><string>并行 Session 数</string></property></widget>
       </item>
       <item row="2" column="1">
        <widget class="QSpinBox" name="spinNumSessions">
         <property name="minimum"><number>1</number></property>
         <property name="maximum"><number>32</number></property>
         <property name="value"><number>4</number></property>
         <property name="toolTip"><string>多 session 并行数。
1  = 单连接（默认，最低开销）
2-4 = 推荐家庭/办公场景（2-4 Gbps）
4-8 = 高带宽多核服务器（8-16 Gbps）
启用后客户端会并行建立 N 条 CONNECT-IP session 共享流量。
建议同时勾选下方「多 Session 独立重连」让每条 session 独立重连，互不影响。</string></property>
        </widget>
       </item>
       <item row="3" column="0">
        <widget class="QLabel"><property name="text"><string>启用 TLS Session 缓存</string></property></widget>
       </item>
       <item row="3" column="1">
        <widget class="QCheckBox" name="checkEnableSessionCache"><property name="checked"><bool>true</bool></property></widget>
       </item>
       <item row="4" column="0">
        <widget class="QLabel"><property name="text"><string>Session 缓存大小</string></property></widget>
       </item>
       <item row="4" column="1">
        <widget class="QSpinBox" name="spinSessionCacheSize">
         <property name="minimum"><number>1</number></property>
         <property name="maximum"><number>10000</number></property>
         <property name="value"><number>128</number></property>
        </widget>
       </item>
       <item row="5" column="0">
        <widget class="QLabel"><property name="text"><string>连接空闲超时（秒）</string></property></widget>
       </item>
       <item row="5" column="1">
        <widget class="QSpinBox" name="spinMaxIdleTimeout">
         <property name="minimum"><number>5</number></property>
         <property name="maximum"><number>600</number></property>
         <property name="value"><number>45</number></property>
         <property name="suffix"><string> s</string></property>
        </widget>
       </item>
       <item row="6" column="0">
        <widget class="QLabel"><property name="text"><string>Keep-Alive 周期（秒）</string></property></widget>
       </item>
       <item row="6" column="1">
        <widget class="QSpinBox" name="spinKeepAlivePeriod">
         <property name="minimum"><number>1</number></property>
         <property name="maximum"><number>300</number></property>
         <property name="value"><number>15</number></property>
         <property name="suffix"><string> s</string></property>
        </widget>
       </item>
       <item row="7" column="0">
        <widget class="QLabel"><property name="text"><string>地址分配超时（秒）</string></property></widget>
       </item>
       <item row="7" column="1">
        <widget class="QSpinBox" name="spinAddressAssignTimeout">
         <property name="minimum"><number>5</number></property>
         <property name="maximum"><number>120</number></property>
         <property name="value"><number>30</number></property>
        </widget>
       </item>
       <item row="8" column="0">
        <widget class="QLabel"><property name="text"><string>最大重连延迟（秒）</string></property></widget>
       </item>
       <item row="8" column="1">
        <widget class="QSpinBox" name="spinMaxReconnectDelay">
         <property name="minimum"><number>1</number></property>
         <property name="maximum"><number>300</number></property>
         <property name="value"><number>30</number></property>
        </widget>
       </item>

       <!-- Bypass -->
       <item row="9" column="0">
        <widget class="QLabel"><property name="text"><string>启用路由绕行 (Bypass)</string></property></widget>
       </item>
       <item row="9" column="1">
        <layout class="QHBoxLayout">
         <item>
          <widget class="QCheckBox" name="checkEnableBypass">
           <property name="checked"><bool>true</bool></property>
           <property name="toolTip"><string>防止隧道流量回环，通常应保持开启</string></property>
          </widget>
         </item>
         <item>
          <widget class="QCheckBox" name="checkBypassStrict">
           <property name="text"><string>严格模式（探测失败报错）</string></property>
           <property name="toolTip"><string>严格模式：bypass 探测失败时直接报错，而不是降级到默认路由。
适合对回环敏感的生产环境，调试时建议关闭以便降级排查。</string></property>
          </widget>
         </item>
        </layout>
       </item>

       <!-- HTTP3 窗口调优 -->
       <item row="10" column="0">
        <widget class="QLabel"><property name="text"><string>禁用路径 MTU 探测</string></property></widget>
       </item>
       <item row="10" column="1">
        <widget class="QCheckBox" name="checkDisablePathMTUProbe"/>
       </item>
       <item row="11" column="0">
        <widget class="QLabel"><property name="text"><string>初始流窗口 (bytes)</string></property></widget>
       </item>
       <item row="11" column="1">
        <widget class="QSpinBox" name="spinInitialStreamWindow">
         <property name="minimum"><number>65536</number></property>
         <property name="maximum"><number>2147483647</number></property>
         <property name="value"><number>16777216</number></property>
         <property name="singleStep"><number>1048576</number></property>
        </widget>
       </item>
       <item row="12" column="0">
        <widget class="QLabel"><property name="text"><string>最大流窗口 (bytes)</string></property></widget>
       </item>
       <item row="12" column="1">
        <widget class="QSpinBox" name="spinMaxStreamWindow">
         <property name="minimum"><number>65536</number></property>
         <property name="maximum"><number>2147483647</number></property>
         <property name="value"><number>67108864</number></property>
         <property name="singleStep"><number>1048576</number></property>
        </widget>
       </item>
       <item row="13" column="0">
        <widget class="QLabel"><property name="text"><string>初始连接窗口 (bytes)</string></property></widget>
       </item>
       <item row="13" column="1">
        <widget class="QSpinBox" name="spinInitialConnWindow">
         <property name="minimum"><number>65536</number></property>
         <property name="maximum"><number>2147483647</number></property>
         <property name="value"><number>33554432</number></property>
         <property name="singleStep"><number>1048576</number></property>
        </widget>
       </item>
       <item row="14" column="0">
        <widget class="QLabel"><property name="text"><string>最大连接窗口 (bytes)</string></property></widget>
       </item>
       <item row="14" column="1">
        <widget class="QSpinBox" name="spinMaxConnWindow">
         <property name="minimum"><number>65536</number></property>
         <property name="maximum"><number>2147483647</number></property>
         <property name="value"><number>134217728</number></property>
         <property name="singleStep"><number>1048576</number></property>
        </widget>
       </item>

       <!-- 注意：原 row 15-17 (disable_compression / tls_handshake_timeout / max_response_header_sec)
            已于 2026-04 移除 —— CONNECT-IP 走 datagram + capsule 路径，没有 HTTP 响应头与
            HTTP3 压缩协商；内核已删除对应字段。row 18+ 编号保持不变以最小化布局抖动。 -->

       <!-- 拥塞控制 -->
       <item row="18" column="0">
        <widget class="QLabel"><property name="text"><string>拥塞控制算法</string></property></widget>
       </item>
       <item row="18" column="1">
        <widget class="QComboBox" name="comboCongestionAlgo">
         <item><property name="text"><string>bbr2（推荐，对抗运营商 QoS）</string></property></item>
         <item><property name="text"><string>cubic（默认，理想网络）</string></property></item>
        </widget>
       </item>
       <!-- Obfs 混淆配置 -->
       <item row="19" column="0">
        <widget class="QLabel"><property name="text"><string>Obfs 混淆类型</string></property></widget>
       </item>
       <item row="19" column="1">
        <widget class="QComboBox" name="comboObfsType">
         <item><property name="text"><string>禁用</string></property></item>
         <item><property name="text"><string>Salamander（规避 DPI）</string></property></item>
        </widget>
       </item>
       <item row="20" column="0">
        <widget class="QLabel"><property name="text"><string>Obfs 混淆密码</string></property></widget>
       </item>
       <item row="20" column="1">
        <widget class="QLineEdit" name="editObfsPassword">
         <property name="placeholderText"><string>预共享密码（客户端和服务端必须相同）</string></property>
         <property name="toolTip"><string>Salamander 混淆可规避运营商对 QUIC Long Header 的 DPI 识别</string></property>
         <property name="echoMode"><enum>QLineEdit::PasswordEchoOnEdit</enum></property>
        </widget>
       </item>
       <!-- 应用层心跳（CONNECT-IP capsule ping/pong） -->
       <item row="21" column="0">
        <widget class="QLabel"><property name="text"><string>应用层心跳周期</string></property></widget>
       </item>
       <item row="21" column="1">
        <widget class="QSpinBox" name="spinAppKeepalivePeriod">
         <property name="minimum"><number>0</number></property>
         <property name="maximum"><number>600</number></property>
         <property name="value"><number>25</number></property>
         <property name="suffix"><string> s</string></property>
         <property name="specialValueText"><string>禁用</string></property>
         <property name="toolTip"><string>CONNECT-IP capsule 应用层 ping 发送周期。
0 = 禁用应用层心跳（仅依赖 QUIC Keep-Alive）。</string></property>
        </widget>
       </item>
       <item row="22" column="0">
        <widget class="QLabel"><property name="text"><string>应用层心跳超时</string></property></widget>
       </item>
       <item row="22" column="1">
        <widget class="QSpinBox" name="spinAppKeepaliveTimeout">
         <property name="minimum"><number>1</number></property>
         <property name="maximum"><number>600</number></property>
         <property name="value"><number>30</number></property>
         <property name="suffix"><string> s</string></property>
         <property name="toolTip"><string>单次 ping 等 pong 的超时时间。</string></property>
        </widget>
       </item>
       <item row="23" column="0">
        <widget class="QLabel"><property name="text"><string>不健康判定阈值</string></property></widget>
       </item>
       <item row="23" column="1">
        <widget class="QSpinBox" name="spinUnhealthyThreshold">
         <property name="minimum"><number>1</number></property>
         <property name="maximum"><number>100</number></property>
         <property name="value"><number>3</number></property>
         <property name="suffix"><string> 次</string></property>
         <property name="toolTip"><string>连续 N 次心跳超时则视为 session 不健康并触发重连。</string></property>
        </widget>
       </item>
       <item row="24" column="0">
        <widget class="QLabel"><property name="text"><string>多 Session 独立重连</string></property></widget>
       </item>
       <item row="24" column="1">
        <widget class="QCheckBox" name="checkPerSessionReconnect">
         <property name="checked"><bool>true</bool></property>
         <property name="toolTip"><string>开启后多 session 模式下每条 session 独立重连，互不影响。</string></property>
        </widget>
       </item>
       <!-- UDP socket buffer & GSO（性能调优） -->
       <item row="25" column="0">
        <widget class="QLabel" name="labelUDPRecvBuffer"><property name="text"><string>UDP 接收缓冲区</string></property></widget>
       </item>
       <item row="25" column="1">
        <widget class="QSpinBox" name="spinUDPRecvBuffer">
         <property name="minimum"><number>65536</number></property>
         <property name="maximum"><number>2147483647</number></property>
         <property name="value"><number>16777216</number></property>
         <property name="singleStep"><number>1048576</number></property>
         <property name="suffix"><string> B</string></property>
         <property name="toolTip"><string>UDP socket 接收缓冲区大小（字节），默认 16 MB。
Linux 高带宽场景可增大到 32-64 MB（需 sysctl 放开 net.core.rmem_max）。
Windows / macOS 内核会把超过系统上限的值静默 cap，配置过大无效。</string></property>
        </widget>
       </item>
       <item row="26" column="0">
        <widget class="QLabel" name="labelUDPSendBuffer"><property name="text"><string>UDP 发送缓冲区</string></property></widget>
       </item>
       <item row="26" column="1">
        <widget class="QSpinBox" name="spinUDPSendBuffer">
         <property name="minimum"><number>65536</number></property>
         <property name="maximum"><number>2147483647</number></property>
         <property name="value"><number>16777216</number></property>
         <property name="singleStep"><number>1048576</number></property>
         <property name="suffix"><string> B</string></property>
         <property name="toolTip"><string>UDP socket 发送缓冲区大小（字节），默认 16 MB。
Linux 同 net.core.wmem_max；其他平台同样会被系统静默 cap。</string></property>
        </widget>
       </item>
       <item row="27" column="0">
        <widget class="QLabel" name="labelEnableGSO"><property name="text"><string>启用 GSO/GRO（仅 Linux）</string></property></widget>
       </item>
       <item row="27" column="1">
        <widget class="QCheckBox" name="checkEnableGSO">
         <property name="checked"><bool>true</bool></property>
         <property name="toolTip"><string>启用 Linux 内核的 GSO（UDP 分段卸载）/ GRO（接收合并）以提升 UDP 吞吐。
• Linux：建议保持开启；显式关闭会通过 QUIC_GO_DISABLE_GSO 环境变量传给 quic-go
• Windows / macOS：内核会自动按平台能力降级，此开关无实际作用</string></property>
        </widget>
       </item>
       <!-- ── BBRv2 子参数（仅 congestion=bbr2 时生效，留空 / 0 = 内核默认）── -->
       <item row="28" column="0" colspan="2">
        <widget class="QLabel">
         <property name="text"><string>━━━ BBRv2 高级参数（仅 bbr2 模式生效，全部留空 = 内核默认）━━━</string></property>
         <property name="styleSheet"><string>color: #666; font-style: italic; margin-top: 6px;</string></property>
        </widget>
       </item>
       <item row="29" column="0">
        <widget class="QLabel"><property name="text"><string>BBRv2 丢包阈值</string></property></widget>
       </item>
       <item row="29" column="1">
        <widget class="QDoubleSpinBox" name="spinBBR2LossThreshold">
         <property name="minimum"><double>0.0</double></property>
         <property name="maximum"><double>1.0</double></property>
         <property name="singleStep"><double>0.005</double></property>
         <property name="decimals"><number>4</number></property>
         <property name="specialValueText"><string>内核默认（0.015）</string></property>
         <property name="toolTip"><string>触发带宽下调的最低丢包率（默认 0.015 即 1.5%）。
运营商随机丢包通常 &lt; 1%，提高此阈值可避免误判拥塞。</string></property>
        </widget>
       </item>
       <item row="30" column="0">
        <widget class="QLabel"><property name="text"><string>BBRv2 Beta（带宽保留比例）</string></property></widget>
       </item>
       <item row="30" column="1">
        <widget class="QDoubleSpinBox" name="spinBBR2Beta">
         <property name="minimum"><double>0.0</double></property>
         <property name="maximum"><double>1.0</double></property>
         <property name="singleStep"><double>0.05</double></property>
         <property name="decimals"><number>3</number></property>
         <property name="specialValueText"><string>内核默认（0.3）</string></property>
         <property name="toolTip"><string>丢包时带宽下调比例，0.3 = 保留 70% 带宽。</string></property>
        </widget>
       </item>
       <item row="31" column="0">
        <widget class="QLabel"><property name="text"><string>BBRv2 Startup 满速轮数</string></property></widget>
       </item>
       <item row="31" column="1">
        <widget class="QSpinBox" name="spinBBR2StartupFullBwRounds">
         <property name="minimum"><number>0</number></property>
         <property name="maximum"><number>20</number></property>
         <property name="value"><number>0</number></property>
         <property name="specialValueText"><string>内核默认（3）</string></property>
         <property name="toolTip"><string>判定带宽已达瓶颈所需的连续轮数。</string></property>
        </widget>
       </item>
       <item row="32" column="0">
        <widget class="QLabel"><property name="text"><string>BBRv2 ProbeRTT 周期（秒）</string></property></widget>
       </item>
       <item row="32" column="1">
        <widget class="QSpinBox" name="spinBBR2ProbeRTTPeriod">
         <property name="minimum"><number>0</number></property>
         <property name="maximum"><number>600</number></property>
         <property name="value"><number>0</number></property>
         <property name="suffix"><string> s</string></property>
         <property name="specialValueText"><string>内核默认（10s）</string></property>
        </widget>
       </item>
       <item row="33" column="0">
        <widget class="QLabel"><property name="text"><string>BBRv2 ProbeRTT 持续（毫秒）</string></property></widget>
       </item>
       <item row="33" column="1">
        <widget class="QSpinBox" name="spinBBR2ProbeRTTDuration">
         <property name="minimum"><number>0</number></property>
         <property name="maximum"><number>5000</number></property>
         <property name="value"><number>0</number></property>
         <property name="suffix"><string> ms</string></property>
         <property name="specialValueText"><string>内核默认（200ms）</string></property>
        </widget>
       </item>
       <item row="34" column="0">
        <widget class="QLabel"><property name="text"><string>BBRv2 BwLo 下调策略</string></property></widget>
       </item>
       <item row="34" column="1">
        <widget class="QComboBox" name="comboBBR2BwLoReduction">
         <property name="toolTip"><string>带宽下调策略：default / minrtt / inflight / cwnd
留空 = 走内核默认（default）</string></property>
         <item><property name="text"><string>内核默认（default）</string></property></item>
         <item><property name="text"><string>default</string></property></item>
         <item><property name="text"><string>minrtt</string></property></item>
         <item><property name="text"><string>inflight</string></property></item>
         <item><property name="text"><string>cwnd</string></property></item>
        </widget>
       </item>
       <item row="35" column="0">
        <widget class="QLabel"><property name="text"><string>BBRv2 激进模式</string></property></widget>
       </item>
       <item row="35" column="1">
        <widget class="QCheckBox" name="checkBBR2Aggressive">
         <property name="toolTip"><string>初始窗口更大，适合高带宽低延迟线路。</string></property>
        </widget>
       </item>
       <!-- ── 管理 API ── -->
       <item row="36" column="0" colspan="2">
        <widget class="QLabel">
         <property name="text"><string>━━━ 管理 / 调试 API（admin_listen / admin_token / pprof）━━━</string></property>
         <property name="styleSheet"><string>color: #666; font-style: italic; margin-top: 6px;</string></property>
        </widget>
       </item>
       <item row="37" column="0">
        <widget class="QLabel"><property name="text"><string>Admin 监听地址</string></property></widget>
       </item>
       <item row="37" column="1">
        <widget class="QLineEdit" name="editAdminListen">
         <property name="placeholderText"><string>留空 = 自动分配 127.0.0.1:0；自定义如 127.0.0.1:9091</string></property>
         <property name="toolTip"><string>客户端管理 / 统计 API 监听地址。
留空时 GUI 自动用 127.0.0.1:0（随机端口）。
非 loopback 地址（如 0.0.0.0:9091）必须设置 admin_token，否则内核拒绝启动。</string></property>
        </widget>
       </item>
       <item row="38" column="0">
        <widget class="QLabel"><property name="text"><string>Admin Token (Bearer)</string></property></widget>
       </item>
       <item row="38" column="1">
        <widget class="QLineEdit" name="editAdminToken">
         <property name="placeholderText"><string>非 loopback 监听时必填</string></property>
         <property name="echoMode"><enum>QLineEdit::PasswordEchoOnEdit</enum></property>
        </widget>
       </item>
       <item row="39" column="0">
        <widget class="QLabel"><property name="text"><string>启用 pprof 性能分析</string></property></widget>
       </item>
       <item row="39" column="1">
        <widget class="QCheckBox" name="checkEnablePprof">
         <property name="toolTip"><string>暴露 /debug/pprof/* 端点（受 admin_token 保护）。
仅排障用，生产环境慎开。</string></property>
        </widget>
       </item>
       <!-- 调试 -->
       <item row="40" column="0">
        <widget class="QLabel"><property name="text"><string>TLS Key Log 路径</string></property></widget>
       </item>
       <item row="40" column="1">
        <widget class="QLineEdit" name="editKeyLogPath">
         <property name="placeholderText"><string>留空不启用（Wireshark 调试用）</string></property>
        </widget>
       </item>
      </layout>
     </widget>

    </widget>
   </item>

   <!-- 确定 / 取消 -->
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="standardButtons">
      <set>QDialogButtonBox::Ok|QDialogButtonBox::Cancel</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <connections>
  <connection>
   <sender>buttonBox</sender><signal>accepted()</signal>
   <receiver>EditNodeDialog</receiver><slot>accept()</slot>
  </connection>
  <connection>
   <sender>buttonBox</sender><signal>rejected()</signal>
   <receiver>EditNodeDialog</receiver><slot>reject()</slot>
  </connection>
 </connections>
</ui>
